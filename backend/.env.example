OPENAI_API_KEY=YOUR_OPENAI_TOKEN_HERE
TAVILY_API_KEY=YOUR_TAVILY_TOKEN_HERE

# OpenAI request settings (default: standard auto tier)
OPENAI_SERVICE_TIER=auto
OPENAI_TIMEOUT_SECONDS=900
# OPENAI_DEBUG_PROMPTS=false

# Local confidential paper corpus (gitignored)
PAPER_RECORDS_PATH=/absolute/path/to/your/paper_database.pkl
PICKLE_PATH=./data/filtered_records_rohan.pkl

# Offline pipeline settings
TOP_N_SOURCES=50
EXTRACTION_CONCURRENCY=4
OUTPUT_DIR=./outputs
CACHE_DIR=./cache

# Prepared database served to the frontend (sample file for development)
TECH_DATABASE_PATH=./data/sample_technology_database.json
